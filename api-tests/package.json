{
  "name": "luxe-api-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright API automation for LUXE Travel Platform microservices",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "report:allure": "allure generate ./allure-results --clean -o ./allure-report",
    "report:allure:ci": "node scripts/write-allure-ci-meta.mjs && npm run report:allure",
    "wait:services": "node scripts/wait-for-services.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "dotenv": "^16.4.5",
    "typescript": "^5.7.2",
    "zod": "^3.23.8"
  }
}
